{
  "manifest_version": 3,
  "name": "OneNote to Mail Draft",
  "version": "0.1.0",
  "description": "Extract structured data from OneNote Web and generate a reviewable Gmail draft, fully client-side and without backend or AI.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://*.onenote.com/*",
    "https://*.office.com/*",
    "https://*.officeapps.live.com/*",
    "https://*.sharepoint.com/*",
    "https://onedrive.live.com/*",
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.onenote.com/*",
        "https://*.office.com/*",
        "https://*.officeapps.live.com/*",
        "https://*.sharepoint.com/*",
        "https://onedrive.live.com/*"
      ],
      "js": ["content/onenote.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/gmail.js"],
      "run_at": "document_idle"
    }
  ]
}